# AWP Growth Portal staging environment.
# Copy these values into the Vercel custom "staging" environment attached to the staging branch.

APP_ENV=staging
APP_BASE_URL=https://staging.awp.wnyautomation.com
NEXT_PUBLIC_APP_BASE_URL=https://staging.awp.wnyautomation.com
NEXT_PUBLIC_APP_URL=https://staging.awp.wnyautomation.com

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_pk_test_from_dedicated_staging_clerk_app
CLERK_SECRET_KEY=sk_live_or_sk_test_from_dedicated_staging_clerk_app
CLERK_EXPECTED_FAPI_HOST=replace-with-staging-clerk-frontend-api-host
NEXT_PUBLIC_CLERK_IS_SATELLITE=true
NEXT_PUBLIC_CLERK_PROXY_URL=https://staging.awp.wnyautomation.com/clerk-proxy
CLERK_PROXY_VERIFICATION_URL=https://staging.awp.wnyautomation.com/clerk-proxy
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://staging.app.wnyautomation.com/sign-in?redirect_url=/launch
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://staging.app.wnyautomation.com/sign-up?redirect_url=/launch
NEXT_PUBLIC_ADMIN_PORTAL_URL=https://staging.admin.wnyautomation.com/admin

# Use the same isolated Neon staging branch as admin and gateway.
DATABASE_URL=postgres://staging-user:staging-password@staging-host/staging-db?sslmode=require
DATABASE_DIRECT_URL=postgres://staging-user:staging-password@staging-host/staging-db?sslmode=require

PORTAL_GATEWAY_URL=https://staging.app.wnyautomation.com
NEXT_PUBLIC_PORTAL_GATEWAY_URL=https://staging.app.wnyautomation.com
PORTAL_GATEWAY_SERVICE_TOKEN=replace-with-shared-staging-token
PORTAL_GATEWAY_DESTINATION_KEY=awp-growth-portal
PORTAL_GATEWAY_FALLBACK_SECRET=replace-with-random-shared-awp-fallback-secret
WNY_INTERNAL_STATUS_TOKEN=replace-with-shared-staging-token

STAGING_PORTAL_URL=https://staging.awp.wnyautomation.com
STAGING_HEALTH_URL=https://staging.awp.wnyautomation.com/api/health

# Required only when running npm run db:seed:staging.
STAGING_SEED_CONFIRM=seed-staging-data
STAGING_AWP_COMPANY_EMAIL=staging-awp@wnyautomation.test
STAGING_AWP_ADMIN_EMAIL=staging.awp.admin@wnyautomation.test

# Keep external integrations mocked or sandboxed.
RECEPTIONIST_PROVIDER=mock
ESTIMATE_DELIVERY_PROVIDER=mock
RETELL_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
STRIPE_SECRET_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
OPENROUTER_API_KEY=
