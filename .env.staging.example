# AWP Growth Portal staging environment.
# Copy these values into the Vercel Preview environment scoped to the staging branch.

APP_ENV=staging
APP_BASE_URL=https://wnyautomation-portal-git-staging-wny-automation.vercel.app
NEXT_PUBLIC_APP_BASE_URL=https://wnyautomation-portal-git-staging-wny-automation.vercel.app
NEXT_PUBLIC_APP_URL=https://wnyautomation-portal-git-staging-wny-automation.vercel.app

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_PROXY_URL=https://wnyautomation.com/clerk-proxy
NEXT_PUBLIC_ADMIN_PORTAL_URL=https://wnyautomation-admin-git-staging-ethanfleury03s-projects.vercel.app/admin

# Use the same isolated Neon staging branch as admin and gateway.
DATABASE_URL=postgres://staging-user:staging-password@staging-host/staging-db?sslmode=require
DATABASE_DIRECT_URL=postgres://staging-user:staging-password@staging-host/staging-db?sslmode=require

PORTAL_GATEWAY_URL=https://wnyautomation-portal-gateway-git-staging-wny-automation.vercel.app
PORTAL_GATEWAY_SERVICE_TOKEN=replace-with-shared-staging-token
PORTAL_GATEWAY_DESTINATION_KEY=awp-growth-portal
WNY_INTERNAL_STATUS_TOKEN=replace-with-shared-staging-token

STAGING_PORTAL_URL=https://wnyautomation-portal-git-staging-wny-automation.vercel.app
STAGING_HEALTH_URL=https://wnyautomation-portal-git-staging-wny-automation.vercel.app/api/health

# Required only when running npm run db:seed:staging.
STAGING_SEED_CONFIRM=seed-staging-data
STAGING_AWP_COMPANY_EMAIL=staging-awp@wnyautomation.test
STAGING_AWP_ADMIN_EMAIL=staging.awp.admin@wnyautomation.test

# Keep external integrations mocked or sandboxed.
RECEPTIONIST_PROVIDER=mock
ESTIMATE_DELIVERY_PROVIDER=mock
RETELL_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
STRIPE_SECRET_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
OPENROUTER_API_KEY=
